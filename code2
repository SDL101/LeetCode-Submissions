/**
 * @file we2.h
 * @brief API for Himax WiseEye 2 (WE2) over I3C.
 *
 * OVERVIEW:
 * This header provides the I3C interface for the Himax WE2 smart camera sensor.
 * The WE2 is an AI-powered camera that detects people, track pose, attention,
 * distance, and bounding box coordinates - all processed on-chip.
 *
 * I3C COMMAND FORMAT (Himax spec):
 * Commands use Type (0x01), Command code, Flag (0x05 request / 0x06 response),
 * Payload Length, and optional Payload. See WE2_I3C_CMD_* and WE2_I3C_FLAG_*.
 *
 * EXAMPLE USAGE:
 *   const struct device *i3c0 = DEVICE_DT_GET(I3C0_DEV_NODE);
 *   if (we2_init(i3c0) != 0) { ... }
 *   uint8_t buffer[WE2_BUF_SIZE];
 *   int len = WE2_BUF_SIZE;
 *   if (we2_read(i3c0, buffer, &len) == 0) { ... }  // 33 bytes (first 3 users)
 *
 * READ-METADATA RESPONSE:
 * I3C read-metadata response: 4-byte header (Type, Cmd, Flag, PayloadLen 0x32) + 50 bytes payload.
 * We copy the first 3 users (33 bytes) into the caller buffer (WE2_BUF_SIZE).
 */

#ifndef WE_2_H
#define WE_2_H

#include <zephyr/kernel.h>
#include <zephyr/device.h>
#include <zephyr/drivers/i3c.h>
#include <zephyr/sys/crc.h>
#include <string.h>

#ifdef __cplusplus
extern "C" {
#endif

/** Resolution values for I3C set resolution (Cmd 0x15): 0x01 = 162x122, 0x02 = 324x224. */
#define WE2_RES_QQVGA 0x01
#define WE2_RES_QVGA  0x02

/** FPS values for I3C set frame rate (Cmd 0x16): 1–5. */
#define WE2_FPS_3 0x03
#define WE2_FPS_5 0x05

/* --- I3C command format (Himax I3C spec: Type, Command, Flag, Payload Length [, Payload]) --- */
/** WE2 static I3C address (used for DAA; use dynamic address for transfers). */
#define WE2_I3C_STATIC_ADDR 0x20
/** Expected 48-bit Provisioned ID for Himax WE2 (from devicetree / datasheet). */
#define WE2_EXPECTED_PID 0x02C400130000ULL
/** I3C command type for metadata/resolution/frame-rate. */
#define WE2_I3C_CMD_TYPE 0x01
/** Write metadata trigger (host command). Type 0x01, Cmd 0x13, Flag 0x05, PayloadLen 0x00. */
#define WE2_I3C_CMD_WRITE_METADATA_TRIGGER 0x13
/** Read metadata (host command). Type 0x01, Cmd 0x14, Flag 0x05, PayloadLen 0x00. Response: Flag 0x06, PayloadLen 0x32 (50 bytes). */
#define WE2_I3C_CMD_READ_METADATA 0x14
/** Set sensor resolution (I3C 0x15). PayloadLen 0x01; payload 0x01 = 162x122, 0x02 = 324x224. */
#define WE2_I3C_CMD_SET_RESOLUTION 0x15
/** Set frame rate (I3C 0x16). PayloadLen 0x01; payload = FPS (1–5). */
#define WE2_I3C_CMD_SET_FRAME_RATE 0x16
/** I3C host command flag (request). */
#define WE2_I3C_FLAG_HOST_CMD 0x05
/** I3C response flag (expected in device response). */
#define WE2_I3C_FLAG_RESPONSE 0x06
/** I3C command header length for no-payload commands (Type + Command + Flag + Payload Length). */
#define WE2_I3C_CMD_HEADER_LEN 4
/** Read-metadata response payload length per doc (0x32 = 50 bytes). Total response = 4-byte header + 50 = 54 bytes (or use 56 if CRC appended). */
#define WE2_I3C_READ_METADATA_RESPONSE_PAYLOAD_LEN 0x32
/** Payload length for set resolution / set frame rate (one byte). */
#define WE2_I3C_SET_RESOLUTION_PAYLOAD_LEN 1
#define WE2_I3C_SET_FRAME_RATE_PAYLOAD_LEN 1

/** Total read-metadata response length: 4-byte header + 50-byte payload (per doc). */
#define WE2_I3C_READ_METADATA_RESPONSE_LEN (WE2_I3C_CMD_HEADER_LEN + WE2_I3C_READ_METADATA_RESPONSE_PAYLOAD_LEN)

/**
 * @brief Buffer size constant for WE2 sensor data (first 3 users only, no CRC)
 *
 * This is used by the sensor abstraction layer to allocate buffers large enough
 * to hold WE2 data. We only send the first 3 users' data (User0 + Non-user1 + Non-user2)
 * plus the header, excluding the CRC bytes.
 * 
 * Data included:
 * - Bytes 0-5: Header (6 bytes)
 * - Bytes 6-18: User0 data (13 bytes)
 * - Bytes 19-25: Non-user1 data (7 bytes)
 * - Bytes 26-32: Non-user2 data (7 bytes)
 * Total: 33 bytes
 *
 * Example: In main.c, MAX_SENSOR_BUF_SIZE uses this to ensure buffers are big enough
 *          for all sensors, including WE2.
 */

 #pragma pack(push, 1)
 typedef struct {
     // User0 data (13 bytes)
     uint8_t user0_confidence;      // Byte 0: User0 Confidence, Range 0-100 (units: percent)
     uint8_t user0_bbox_x;          // Byte 1: User0 Bounding Box X-Coordinate (upper-left corner), Unit: number of pixels
     uint8_t user0_bbox_y;          // Byte 2: User0 Bounding Box Y-Coordinate (upper-left corner), Unit: number of pixels
     uint8_t user0_bbox_width;      // Byte 3: User0 Bounding Box Width, Unit: number of pixels
     uint8_t user0_bbox_height;     // Byte 4: User0 Bounding Box Height, Unit: number of pixels
     uint8_t user0_distance;        // Byte 5: User0 Distance Category, 3: Far (≥8ft), 2: Mid (5ft to 7ft), 1: Near (≤5ft), 0: N/A
     int8_t  user0_angle;           // Byte 6: User0 Angle, Unit: degree, Range: -90 to 90, Polarity: positive on left pane, negative on right pane
     uint8_t user0_toward_away;     // Byte 7: User0 Toward or Away, 1: move away, 2: move toward, 0: N/A
     uint8_t user0_pose;            // Byte 8: User0 Sitting or Standing, 2: standing, 1: sitting, 0: N/A
     int8_t  user0_yaw;             // Byte 9: User0 Yaw, Unit: degree
     int8_t  user0_pitch;           // Byte 10: User0 Pitch, Unit: degree
     int8_t  user0_roll;            // Byte 11: User0 Roll, Unit: degree
     uint8_t user0_engaged;         // Byte 12: User0 Engaged, 1: User in attention, 0: User not in attention
 
     // Non-user1 data (7 bytes)
     uint8_t nonuser1_confidence;   // Byte 13: Non-user1 Confidence, Range 0-100 (units: percent)
     uint8_t nonuser1_bbox_x;       // Byte 14: Non-user1 Bounding Box X-Coordinate (upper-left corner), Unit: number of pixels
     uint8_t nonuser1_bbox_y;       // Byte 15: Non-user1 Bounding Box Y-Coordinate (upper-left corner), Unit: number of pixels
     uint8_t nonuser1_bbox_width;   // Byte 16: Non-user1 Bounding Box Width, Unit: number of pixels
     uint8_t nonuser1_bbox_height;  // Byte 17: Non-user1 Bounding Box Height, Unit: number of pixels
     uint8_t nonuser1_distance;     // Byte 18: Non-user1 Distance Category, 3: Far (≥8ft), 2: Mid (5ft to 7ft), 1: Near (≤5ft), 0: N/A
     int8_t  nonuser1_angle;       // Byte 19: Non-user1 Angle, Polarity: positive on left, negative on right
 
     // Non-user2 data (7 bytes)
     uint8_t nonuser2_confidence;   // Byte 20: Non-user2 Confidence, Range 0-100 (units: percent)
     uint8_t nonuser2_bbox_x;      // Byte 21: Non-user2 Bounding Box X-Coordinate (upper-left corner), Unit: number of pixels
     uint8_t nonuser2_bbox_y;      // Byte 22: Non-user2 Bounding Box Y-Coordinate (upper-left corner), Unit: number of pixels
     uint8_t nonuser2_bbox_width;  // Byte 23: Non-user2 Bounding Box Width, Unit: number of pixels
     uint8_t nonuser2_bbox_height; // Byte 24: Non-user2 Bounding Box Height, Unit: number of pixels
     uint8_t nonuser2_distance;    // Byte 25: Non-user2 Distance Category, 3: Far (≥8ft), 2: Mid (5ft to 7ft), 1: Near (≤5ft), 0: N/A
     int8_t  nonuser2_angle;       // Byte 26: Non-user2 Angle, Polarity: positive on left, negative on right
 } we2_sample_t;
 #pragma pack(pop)
 
 #define WE2_BUF_SIZE sizeof(we2_sample_t)

/**
 * @brief Initialize WE2 sensor: find WE2, check dynamic address, set resolution and FPS.
 *
 * Finds WE2 by static address, verifies dynamic address is assigned, then sets
 * resolution (e.g. QVGA) and frame rate (e.g. 3 fps) via I3C. Must be called
 * before we2_read().
 *
 * @param i3c_bus I3C controller device (e.g. i3c0).
 * @return 0 if WE2 descriptor found and dynamic address assigned, negative errno otherwise.
 */
int we2_init(const struct device *i3c_bus);

/**
 * @brief Set WE2 resolution over I3C (Cmd 0x15). Payload 0x01 = 162x122, 0x02 = 324x224.
 * @param i3c_bus I3C controller device (e.g. i3c0); we2_i3c_desc must already be set.
 * @param res WE2_RES_QQVGA (0x01) or WE2_RES_QVGA (0x02).
 * @return 0 on success, negative errno on failure.
 */
int we2_set_resolution(const struct device *i3c_bus, uint8_t res);

/**
 * @brief Set WE2 frame rate over I3C (Cmd 0x16). Payload = FPS (1–5).
 * @param i3c_bus I3C controller device (e.g. i3c0); we2_i3c_desc must already be set.
 * @param fps Frame rate 1–5 (e.g. WE2_FPS_3, WE2_FPS_5).
 * @return 0 on success, negative errno on failure.
 */
int we2_set_fps(const struct device *i3c_bus, uint8_t fps);

/**
 * @brief Read metadata from WE2 sensor over I3C.
 *
 * Sends I3C read-metadata command (Type 0x01, Command 0x14, Flag 0x05), then reads
 * the response. Returns 33-byte output format (first 3 users, no CRC).
 *
 * @param i3c_bus I3C controller device (e.g. i3c0); must match bus used in we2_init().
 * @param out_buf Buffer for response data (at least WE2_BUF_SIZE bytes).
 * @param out_len On input buffer size; on output number of bytes written.
 * @return 0 on success, negative errno on failure.
 */
int we2_read(const struct device *i3c_bus, void *out_buf, int *out_len);

#ifdef __cplusplus
}
#endif

#endif /* WE_2_H */
