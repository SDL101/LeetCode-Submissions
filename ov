#include <dt-bindings/pinctrl/balletto-pinctrl.h>
#include <dt-bindings/i2c/i2c.h>
#include <dt-bindings/gpio/gpio.h>

#define LPSPI_SS_SW_CONTROLLED_GPIO 1

&pinctrl_i2c0 {
	group0 {
		pinmux = <PIN_P7_0__I2C0_SDA_C>, <PIN_P7_1__I2C0_SCL_C>;
	};
};

&i2c0 {
	status = "okay";
	clock-frequency = <400000>;
	pinctrl-0 = <&pinctrl_i2c0>;
	pinctrl-names = "default";
};

&pinctrl_i2c1 {
	group0 {
		pinmux = <PIN_P7_2__I2C1_SDA_C>, <PIN_P7_3__I2C1_SCL_C>;
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <400000>;
	pinctrl-0 = <&pinctrl_i2c1>;
	pinctrl-names = "default";
};

&ns {
	status = "okay";
};

&sdhc {
	status = "okay";
};


&gpio6 {
	status = "okay";
};

&pinctrl_i3c0 {
	group0 {
		pinmux = <PIN_P0_6__I3C_SDA_A>, <PIN_P0_5__I3C_SCL_A>;
		read-enable = <0x1>;
	};
};

&i3c0 {
	status = "okay";
	pinctrl-0 = <&pinctrl_i3c0>;
	pinctrl-names = "default";

	/* WE2: static 0x20, PID 0x2C400130000 (doc). reg = static, pid_high32, pid_low32. */
	himax_we2: himax_we2@20 {
		compatible = "vnd,i3c-device";
		reg = <0x20 0x00002C40 0x0130000>;
		supports-setaasa;
	};
};
