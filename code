/**
 * @brief Read metadata from WE2 sensor over I3C.
 * Requires we2_init() first. Sends read-metadata command then reads response.
 */
int we2_read(const struct device *i3c_bus, void *out_buf, int *out_len)
{
	uint8_t trigger_cmd[WE2_I3C_CMD_HEADER_LEN]; /* Write metadata trigger (0x13) per doc */
	uint8_t read_cmd[WE2_I3C_CMD_HEADER_LEN];   /* Read metadata (0x14) */
	uint8_t resp[WE2_I3C_READ_METADATA_RESPONSE_LEN]; /* 4-byte header + 50 payload per doc */
	int ret;
	const struct device *gpio6_dev = DEVICE_DT_GET(DT_NODELABEL(gpio6));

	printk("\r\n[WE2 DBG] ========== we2_read START ==========\r\n");
	printk("[WE2 DBG] we2_i3c_desc DA=0x%02X, out_buf=%p out_len=%p\r\n",
	       we2_i3c_desc ? we2_i3c_desc->dynamic_addr : 0, (void *)out_buf, (void *)out_len);

	if (we2_i3c_desc == NULL) {
		printk("[ERROR] WE2 I3C read: init not done (call we2_init first)\r\n");
		return -ENODEV;
	}
	if (!device_is_ready(gpio6_dev)) {
		printk("[ERROR] WE2 I3C read: gpio6 not ready\r\n");
		return -ENODEV;
	}

	/* Per Himax doc: 1) Write metadata trigger (0x13), then 2) Read metadata (0x14). */
	trigger_cmd[0] = WE2_I3C_CMD_TYPE;
	trigger_cmd[1] = WE2_I3C_CMD_WRITE_METADATA_TRIGGER;
	trigger_cmd[2] = WE2_I3C_FLAG_HOST_CMD;
	trigger_cmd[3] = 0x00;

	read_cmd[0] = WE2_I3C_CMD_TYPE;
	read_cmd[1] = WE2_I3C_CMD_READ_METADATA;
	read_cmd[2] = WE2_I3C_FLAG_HOST_CMD;
	read_cmd[3] = 0x00;
	printk("[WE2 DBG] trigger cmd[] = 0x%02X 0x%02X 0x%02X 0x%02X, read cmd[] = 0x%02X 0x%02X 0x%02X 0x%02X\r\n",
	       trigger_cmd[0], trigger_cmd[1], trigger_cmd[2], trigger_cmd[3],
	       read_cmd[0], read_cmd[1], read_cmd[2], read_cmd[3]);

	ret = gpio_pin_configure(gpio6_dev, WE2_GPIO_PIN, GPIO_OUTPUT_INACTIVE);
	if (ret < 0) {
		printk("[WE2 DBG] gpio_pin_configure FAILED: %d\r\n", ret);
		return ret;
	}

	/*
	 * Read-metadata sequence (all under one GPIO high, per Himax):
	 *   1. GPIO HIGH
	 *   2. Delay 300 ms
	 *   3. Write trigger (0x13)
	 *   4. Delay 200 ms
	 *   5. One transaction: write read-metadata (0x14) then read 54 bytes (repeated START, no STOP between)
	 *   6. GPIO LOW
	 */
	struct i3c_msg read_msgs[2] = {
		{
			.buf = read_cmd,
			.len = sizeof(read_cmd),
			.flags = I3C_MSG_WRITE,
		},
		{
			.buf = resp,
			.len = sizeof(resp),
			.flags = I3C_MSG_READ | I3C_MSG_STOP,
		},
	};

	for (int attempt = 0; attempt <= 2; attempt++) {
		if (attempt > 0) {
			printk("[WE2 DBG] read retry %d/2 after 300 ms (prev ret=%d)\r\n", attempt, ret);
			k_msleep(300);
		}

		/* 1. GPIO HIGH, 2. Delay 300 ms */
		printk("[WE2 DBG] GPIO P6_7 HIGH, delay 300 ms...\r\n");
		gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 1);
		k_msleep(300);

		/* 3. Write metadata trigger (0x13) */
		ret = i3c_write(we2_i3c_desc, trigger_cmd, sizeof(trigger_cmd));
		printk("[WE2 DBG] i3c_write(trigger 0x13, len=4) -> %d\r\n", ret);
		if (ret < 0) {
			gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 0);
			if (ret != -ENXIO && ret != -EAGAIN) {
				break;
			}
			continue;
		}
		/* 4. Delay 200 ms before read-metadata transfer (give device time to prepare) */
		k_msleep(200);

		/* 5. One transaction: write 0x14 then read 54 (repeated START, no STOP between write and read) */
		ret = i3c_transfer(we2_i3c_desc, read_msgs, 2);
		gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 0);
		printk("[WE2 DBG] i3c_transfer(write 4 + read 54) -> %d\r\n", ret);
		if (ret == 0) {
			break;
		}
		if (ret != -ENXIO && ret != -EAGAIN) {
			break;
		}
	}
	if (ret < 0) {
		printk("[ERROR] WE2 I3C read transfer failed: %d\r\n", ret);
		return ret;
	}

	/* Hex dump first 24 bytes of response (header + start of payload) */
	printk("[WE2 DBG] response first 24 bytes: ");
	for (size_t i = 0; i < 24 && i < sizeof(resp); i++) {
		printk("%02X ", resp[i]);
	}
	printk("\r\n");
	printk("[WE2 DBG] response bytes 24-47: ");
	for (size_t i = 24; i < 48 && i < sizeof(resp); i++) {
		printk("%02X ", resp[i]);
	}
	printk("\r\n");
	printk("[WE2 DBG] response bytes 48-53 (tail/CRC): ");
	for (size_t i = 48; i < sizeof(resp) && i < 54; i++) {
		printk("%02X ", resp[i]);
	}
	printk("\r\n");

	/* Validate response header: Type 0x01, Cmd 0x14, Flag 0x06, PayloadLen 0x32. */
	if (resp[0] != WE2_I3C_CMD_TYPE || resp[1] != WE2_I3C_CMD_READ_METADATA ||
	    resp[2] != WE2_I3C_FLAG_RESPONSE || resp[3] != WE2_I3C_READ_METADATA_RESPONSE_PAYLOAD_LEN) {
		printk("[ERROR] WE2 I3C read: invalid response header 0x%02X 0x%02X 0x%02X 0x%02X (expected 0x01 0x14 0x06 0x32)\r\n",
		       resp[0], resp[1], resp[2], resp[3]);
		return -EIO;
	}

	ret = we2_validate_response_crc(resp, sizeof(resp));
	printk("[WE2 DBG] we2_validate_response_crc(resp, %zu) -> %d (%s)\r\n",
	       sizeof(resp), ret, ret == 0 ? "CRC OK" : "CRC MISMATCH");
	if (ret != 0) {
		printk("[ERROR] WE2 I3C read: response CRC invalid (not WE2 metadata)\r\n");
		return -EIO;
	}

	/* I3C response: 4-byte header (Type, Cmd, Flag, PayloadLen) + 50-byte payload. Copy first 3 users (33 bytes) from payload; payload layout matches I2C at offset 2 (skip 2 reserved). */
	printk("[WE2 DBG] copy payload resp+6 -> out_buf, len=%d\r\n", WE2_BUF_SIZE);
	memcpy(out_buf, resp + 6, WE2_BUF_SIZE);
	*out_len = WE2_BUF_SIZE;
	printk("[WE2 DBG] we2_read OK, *out_len=%d\r\n", *out_len);

#if WE2_DEBUG_PRINT
	/* Decode fields */
	printk("[INFO] Detailed Metadata:\r\n");
	int line_counter = 1;  // Reset line counter for each read operation
	size_t count = sizeof(descriptions) / sizeof(descriptions[0]);
	for (size_t i = 0; i < count && i < 54; i++) {
		decode_and_print(i, descriptions[i], resp[i], notes[i], &line_counter);
	}
#endif /* WE2_DEBUG_PRINT */

	return 0;
}

/**
 * @brief Build a 6-byte WE2 feature command with CRC.
 *
 * Constructs the command packet:
 * - Bytes 0-3: Command data (feature ID + parameters)
 * - Bytes 4-5: CRC16-CCITT checksum over bytes 0-3 (LSB first)
 *
 * @param cmd Output buffer (must be at least 6 bytes).
 *            On return, contains the complete command ready to send.
 */
static void we2_build_command(uint8_t *cmd)
{
	// Build base command bytes
	// Byte 0: The command type (0x82 = "send me your feature data")
	// Bytes 1-3: Additional command parameters (all zeros for this command)
	cmd[0] = 0x82;  // HIMAX_FEATURE_CMD (kept as constant for compatibility)
	cmd[1] = 0x00;
	cmd[2] = 0x00;
	cmd[3] = 0x00;
	printk("[INFO] Base command prepared: 0x%02X 0x%02X 0x%02X 0x%02X\r\n",
	       cmd[0], cmd[1], cmd[2], cmd[3]);

	// Calculate CRC over the first 4 bytes
	// CRC helps detect if data got corrupted during transmission
	uint16_t cmd_crc_host = crc16_ccitt(0xFFFF, cmd, 4);
	printk("[INFO] Host-calculated command CRC: 0x%04X\r\n", cmd_crc_host);

	// Append CRC as bytes 4-5 (LSB first, then MSB - little-endian format)
	// Example: If CRC = 0x1234, we send [0x34, 0x12] not [0x12, 0x34]
	cmd[4] = (uint8_t)(cmd_crc_host & 0xFF);
	cmd[5] = (uint8_t)((cmd_crc_host >> 8) & 0xFF);

	// Print the complete command for debugging
	printk("[INFO] Full command with CRC: ");
	for (size_t i = 0; i < 6; i++) {
		printk("0x%02X ", cmd[i]);
	}
	printk("\r\n");
}

/**
 * @brief Validate the CRC of a WE2 response.
 *
 * Extracts the CRC from the last 2 bytes of the response (bytes 54-55),
 * calculates what the CRC should be based on bytes 0-53, and compares them.
 *
 * @param resp Pointer to the response buffer (must be at least 56 bytes for I2C format, or 54 bytes for I3C).
 * @param resp_len Length of the response buffer.
 * @return 0 if CRC matches (data is valid), non-zero if mismatch (data corrupted).
 */
static int we2_validate_response_crc(const uint8_t *resp, size_t resp_len)
{
	// For I3C: response is 54 bytes (4-byte header + 50 payload), CRC may be at end
	// For I2C: response was 56 bytes, CRC at bytes 54-55
	// Check if we have enough bytes for CRC validation
	if (resp_len < 54) {
		printk("[WARN] Response too short for CRC validation (%zu bytes)\r\n", resp_len);
		return -1;
	}

	// Extract the CRC that the device sent (last 2 bytes, MSB|LSB format)
	uint16_t resp_crc_device;
	if (resp_len >= 56) {
		// I2C format: CRC at bytes 54-55
		resp_crc_device = ((uint16_t)resp[55] << 8) | resp[54];
	} else {
		// I3C format: assume CRC at bytes 52-53 (if present)
		resp_crc_device = ((uint16_t)resp[53] << 8) | resp[52];
	}

	// Calculate what the CRC SHOULD be based on bytes 0-53 (or 0-51 for I3C)
	size_t crc_len = (resp_len >= 56) ? 54 : (resp_len >= 54 ? 52 : resp_len - 2);
	uint16_t resp_crc_host = crc16_ccitt(0xFFFF, resp, crc_len);

	printk("[INFO] Device CRC: 0x%04X, Host CRC: 0x%04X\r\n",
	       resp_crc_device, resp_crc_host);

	if (resp_crc_device == resp_crc_host) {
		printk("[INFO] Response CRC matches.\r\n");
		return 0;  // CRC valid
	} else {
		printk("[WARN] CRC mismatch!\r\n");
		return -1;  // CRC invalid
	}
}

#if WE2_DEBUG_PRINT
/**
 * @brief Decode a single byte value based on its description/notes and print it.
 *
 * @param index The index of the byte in the response array.
 * @param desc A string description of the byte.
 * @param value The raw byte value.
 * @param note A string containing notes or decoding instructions for the byte.
 * @param line_num Pointer to line counter (will be incremented).
 */
static void decode_and_print(int index, const char *desc, uint8_t value, const char *note, int *line_num)
{
	printk("[Ln %3d] Byte %2d: %s = 0x%02X (%s)",
	       (*line_num)++, index, desc, value, note);

	if (strstr(note, "Unit: degree") != NULL || strstr(note, "Angle") != NULL) {
		printk(" -> %d degrees", (int8_t)value);
	} else if (strstr(note, "Unit: pixels") != NULL) {
		printk(" -> %u px", value);
	} else if (strstr(note, "Range: 0-100") != NULL) {
		printk(" -> %u%%", value);
	} else if (strstr(note, "3-Far; 2-Mid; 1-Near") != NULL) {
		const char *dist = "N/A";
		if (value == 3) dist = "Far";
		else if (value == 2) dist = "Mid";
		else if (value == 1) dist = "Near";
		printk(" -> %s", dist);
	} else if (strstr(note, "1-Away; 2-Toward") != NULL) {
		const char *dir = "N/A";
		if (value == 1) dir = "Away";
		else if (value == 2) dir = "Toward";
		printk(" -> %s", dir);
	} else if (strstr(note, "2-Standing; 1-Sitting") != NULL) {
		const char *pose = "N/A";
		if (value == 2) pose = "Standing";
		else if (value == 1) pose = "Sitting";
		printk(" -> %s", pose);
	} else if (strstr(note, "1-Attention") != NULL) {
		printk(" -> %s", (value == 1) ? "Attention" : "Not");
	}
	printk("\r\n");
}
#endif /* WE2_DEBUG_PRINT */

