/**
 * @file we2.c
 * @brief Read and decode WiseEye 2 (Himax) feature response over I3C.
 *
 * This module provides I3C interface for the Himax WE2 smart camera sensor.
 * The WE2 is an AI-powered camera that detects people, tracks pose, attention,
 * distance, and bounding box coordinates - all processed on-chip.
 */

#include <zephyr/kernel.h>
#include <zephyr/sys/printk.h>
#include <zephyr/device.h>
#include <zephyr/devicetree.h>
#include <zephyr/drivers/i3c.h>
#include <zephyr/drivers/i3c/ccc.h>
#include <zephyr/drivers/i3c/devicetree.h>
#include <zephyr/drivers/gpio.h>
#include <zephyr/sys/crc.h>
#include <string.h>
#include <inttypes.h>
#include <errno.h>
#include "we2.h"

/** GPIO pin for WE2 PA0 (MCU trigger / Special Mode); Alif P6_7 = gpio6 pin 7. */
#define WE2_GPIO_PIN 7

/** WE2 I3C device descriptor (set by we2_init for use by future I3C read/write). */
static struct i3c_device_desc *we2_i3c_desc;

/* Minimal device init for himax_we2 node so I3C controller's device array has a valid .dev. */
static int we2_i3c_device_init(const struct device *dev)
{
	ARG_UNUSED(dev);
	return 0;
}

/*
 * Define the device instance for the himax_we2 devicetree node.
 * The I3C controller driver (i3c_dw) references this device in its child array;
 * without this, we get undefined reference to __device_dts_ord_N at link time.
 */
DEVICE_DT_DEFINE(DT_NODELABEL(himax_we2), we2_i3c_device_init, NULL, NULL, NULL,
		 POST_KERNEL, 70, NULL);

// Debug print toggle: Set to 1 to enable detailed metadata printing, 0 to disable
#define WE2_DEBUG_PRINT 1

/* Forward declarations for helper functions */
static void we2_build_command(uint8_t *cmd);
static int we2_validate_response_crc(const uint8_t *resp, size_t resp_len);
#if WE2_DEBUG_PRINT
static void decode_and_print(int index, const char *desc, uint8_t value, const char *note, int *line_num);
#endif /* WE2_DEBUG_PRINT */

/**
 * @brief Initialize WE2 sensor: scan I3C bus and try set resolution/FPS on each device.
 *
 * Iterates over all I3C devices on the bus (I3C_BUS_FOR_EACH_I3CDEV). For each device
 * with a valid dynamic address, tries SETDASA if needed, then set resolution and set
 * FPS (with GPIO toggles per Himax flowchart). The first device that accepts both
 * commands is stored as we2_i3c_desc for use by we2_read(). No PID or static address
 * lookup is required.
 */
int we2_init(const struct device *i3c_bus)
{
	int ret;
	struct i3c_device_desc *desc;
	int device_index = 0;

	printk("\r\n[WE2 DBG] ========== WE2 I3C INIT START ==========\r\n");
	printk("[WE2 DBG] I3C bus: %s\r\n", i3c_bus->name);

	if (!device_is_ready(i3c_bus)) {
		printk("[ERROR] WE2 I3C: I3C bus not ready\r\n");
		return -ENODEV;
	}
	printk("[WE2 DBG] I3C bus is ready. Clearing we2_i3c_desc, scanning attached I3C devices...\r\n\r\n");

	we2_i3c_desc = NULL;

	I3C_BUS_FOR_EACH_I3CDEV(i3c_bus, desc) {
		device_index++;
		printk("[WE2 DBG] ---------- I3C device #%d ----------\r\n", device_index);
		printk("[WE2 DBG]   dynamic_addr     = 0x%02X\r\n", desc->dynamic_addr);
		printk("[WE2 DBG]   static_addr      = 0x%02X\r\n", desc->static_addr);
		printk("[WE2 DBG]   pid              = 0x%012" PRIx64 "\r\n", (uint64_t)desc->pid);
		printk("[WE2 DBG]   init_dyn_addr    = 0x%02X\r\n", desc->init_dynamic_addr);
		printk("[WE2 DBG]   supports_setaasa = %d\r\n", (int)desc->supports_setaasa);
		printk("[WE2 DBG]   bcr              = 0x%02X  dcr = 0x%02X\r\n", desc->bcr, desc->dcr);
		if (desc->dev != NULL) {
			printk("[WE2 DBG]   dev->name        = %s\r\n", desc->dev->name);
		} else {
			printk("[WE2 DBG]   dev->name        = (null)\r\n");
		}

		/* Skip if no dynamic address; try SETDASA if we have a static address. */
		if (desc->dynamic_addr == 0U) {
			if (desc->static_addr == 0U) {
				printk("[WE2 DBG]   SKIP: no DA and no SA, cannot address device\r\n\r\n");
				continue;
			}
			printk("[WE2 DBG]   No DA yet; attempting SETDASA (SA 0x%02X -> DA 0x%02X)...\r\n",
			       desc->static_addr, desc->static_addr);
			ret = i3c_ccc_do_setdasa(desc,
				(struct i3c_ccc_address){ .addr = (uint8_t)(desc->static_addr << 1) });
			if (ret != 0) {
				printk("[WARN] WE2 I3C: SETDASA failed for SA 0x%02X: ret=%d (skip device)\r\n\r\n",
				       desc->static_addr, ret);
				continue;
			}
			desc->dynamic_addr = desc->static_addr;
			printk("[WE2 DBG]   SETDASA OK -> dynamic_addr now 0x%02X\r\n", desc->dynamic_addr);
		}

		/* Optional: read PID via GETPID. If GETPID NACKs, no device at this DA -> skip. */
		{
			struct i3c_ccc_getpid getpid_payload;
			uint64_t read_pid;
			int pid_ret = i3c_ccc_do_getpid(desc, &getpid_payload);

			if (pid_ret != 0) {
				printk("[WARN] WE2 I3C: GETPID failed at DA 0x%02X: ret=%d (skip device)\r\n\r\n",
				       desc->dynamic_addr, pid_ret);
				continue;
			}
			/* PID from GETPID is big-endian: first byte is MSB. */
			read_pid = ((uint64_t)getpid_payload.pid[0] << 40) |
				   ((uint64_t)getpid_payload.pid[1] << 32) |
				   ((uint64_t)getpid_payload.pid[2] << 24) |
				   ((uint64_t)getpid_payload.pid[3] << 16) |
				   ((uint64_t)getpid_payload.pid[4] << 8)  |
				   (uint64_t)getpid_payload.pid[5];
			if (read_pid != WE2_EXPECTED_PID) {
				/* WE2 may return different GETPID format (e.g. echoes DA 0x20); don't skip. */
				printk("[WARN] WE2 I3C: GETPID at DA 0x%02X read 0x%012" PRIx64 " (expected 0x%012" PRIx64 "); continuing, verification read will confirm.\r\n",
				       desc->dynamic_addr, read_pid, (uint64_t)WE2_EXPECTED_PID);
			} else {
				printk("[WE2 DBG]   GETPID OK: PID 0x%012" PRIx64 " (WE2)\r\n", read_pid);
			}

			/* Optional: read BCR/DCR for sanity and log. */
			{
				struct i3c_ccc_getbcr getbcr_payload = { .bcr = 0 };
				struct i3c_ccc_getdcr getdcr_payload = { .dcr = 0 };
				if (i3c_ccc_do_getbcr(desc, &getbcr_payload) == 0 &&
				    i3c_ccc_do_getdcr(desc, &getdcr_payload) == 0) {
					printk("[WE2 DBG]   GETBCR=0x%02X GETDCR=0x%02X\r\n",
					       getbcr_payload.bcr, getdcr_payload.dcr);
				}
			}
		}

		we2_i3c_desc = desc;

		/*
		 * Decouple from DAA: wait for bus/ENTDAA to settle before first
		 * private transfer (set_resolution). Otherwise i3c_write can get
		 * -ENXIO/-EAGAIN when ENTDAA runs concurrently.
		 */
		printk("[WE2 DBG]   Waiting 800 ms for bus/DAA to settle before set_resolution...\r\n");
		k_msleep(800);

		printk("[WE2 DBG]   Trying WE2 set_resolution(QVGA) on DA 0x%02X...\r\n", desc->dynamic_addr);
		ret = we2_set_resolution(i3c_bus, WE2_RES_QVGA);
		if (ret < 0) {
			/* Retry on NACK (-ENXIO) or semaphore timeout (-EAGAIN) from DAA contention */
			for (int attempt = 1; (ret == -ENXIO || ret == -EAGAIN) && attempt <= 2; attempt++) {
				printk("[WE2 DBG]   set_resolution retry %d/2 after 400 ms (ret=%d)\r\n", attempt, ret);
				k_msleep(400);
				ret = we2_set_resolution(i3c_bus, WE2_RES_QVGA);
			}
		}
		if (ret < 0) {
			printk("[WARN] WE2 I3C: Set resolution failed at DA 0x%02X: ret=%d (try next device)\r\n\r\n",
			       desc->dynamic_addr, ret);
			continue;
		}
		printk("[WE2 DBG]   Set resolution OK. Trying WE2 set_fps(3) on DA 0x%02X...\r\n", desc->dynamic_addr);
		ret = we2_set_fps(i3c_bus, WE2_FPS_3);
		if (ret < 0) {
			for (int attempt = 1; (ret == -ENXIO || ret == -EAGAIN) && attempt <= 2; attempt++) {
				printk("[WE2 DBG]   set_fps retry %d/2 after 400 ms (ret=%d)\r\n", attempt, ret);
				k_msleep(400);
				ret = we2_set_fps(i3c_bus, WE2_FPS_3);
			}
		}
		if (ret < 0) {
			printk("[WARN] WE2 I3C: Set FPS failed at DA 0x%02X: ret=%d (try next device)\r\n\r\n",
			       desc->dynamic_addr, ret);
			continue;
		}

		/* Confirm init with one valid read: only treat success if we get valid WE2 metadata. */
		{
			uint8_t init_buf[WE2_BUF_SIZE];
			int init_len = WE2_BUF_SIZE;

			printk("[WE2 DBG]   Init verification: one we2_read to confirm valid response...\r\n");
			ret = we2_read(i3c_bus, init_buf, &init_len);
			if (ret != 0) {
				printk("[WARN] WE2 I3C: Init verification read failed: %d (try next device)\r\n\r\n", ret);
				continue;
			}
		}

		printk("\r\n[WE2 DBG] ========== WE2 INIT SUCCESS ==========\r\n");
		printk("[INFO] WE2 I3C: WE2 initialized at dynamic address 0x%02X (device #%d, PID 0x%012" PRIx64 ")\r\n",
		       we2_i3c_desc->dynamic_addr, device_index, (uint64_t)we2_i3c_desc->pid);
		return 0;
	}

	we2_i3c_desc = NULL;
	printk("\r\n[WE2 DBG] ========== WE2 INIT FAILED ==========\r\n");
	printk("[ERROR] WE2 I3C: No WE2 device found on bus (tried %d I3C device(s))\r\n", device_index);
	return -ENODEV;
}

/** I3C command buffer: Type + Command + Flag + Payload Length + Payload (5 bytes for set resolution/FPS). */
#define WE2_I3C_CMD_WITH_PAYLOAD_LEN 5

int we2_set_resolution(const struct device *i3c_bus, uint8_t res)
{
	uint8_t cmd[WE2_I3C_CMD_WITH_PAYLOAD_LEN];
	int ret;
	const struct device *gpio6_dev = DEVICE_DT_GET(DT_NODELABEL(gpio6));

	printk("[WE2 DBG] we2_set_resolution: target DA=0x%02X res=0x%02X (%s)\r\n",
	       we2_i3c_desc ? we2_i3c_desc->dynamic_addr : 0,
	       res, res == WE2_RES_QQVGA ? "QQVGA 162x122" : (res == WE2_RES_QVGA ? "QVGA 324x224" : "other"));

	if (we2_i3c_desc == NULL) {
		printk("[ERROR] WE2 I3C: we2_i3c_desc not set (call we2_init first)\r\n");
		return -ENODEV;
	}
	if (!device_is_ready(gpio6_dev)) {
		printk("[ERROR] WE2 I3C: gpio6 not ready\r\n");
		return -ENODEV;
	}

	cmd[0] = WE2_I3C_CMD_TYPE;
	cmd[1] = WE2_I3C_CMD_SET_RESOLUTION;
	cmd[2] = WE2_I3C_FLAG_HOST_CMD;
	cmd[3] = WE2_I3C_SET_RESOLUTION_PAYLOAD_LEN;
	cmd[4] = res;
	printk("[WE2 DBG]   cmd[] = 0x%02X 0x%02X 0x%02X 0x%02X 0x%02X (len=%zu)\r\n",
	       cmd[0], cmd[1], cmd[2], cmd[3], cmd[4], sizeof(cmd));

	ret = gpio_pin_configure(gpio6_dev, WE2_GPIO_PIN, GPIO_OUTPUT_INACTIVE);
	if (ret < 0) {
		printk("[WE2 DBG]   gpio_pin_configure FAILED: %d\r\n", ret);
		return ret;
	}
	printk("[WE2 DBG]   GPIO P6_7 configured OUTPUT_INACTIVE, setting HIGH...\r\n");
	gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 1);
	printk("[WE2 DBG]   delay 20 ms...\r\n");
	k_msleep(20);
	ret = i3c_write(we2_i3c_desc, cmd, sizeof(cmd));
	printk("[WE2 DBG]   i3c_write(DA=0x%02X, len=%zu) -> %d\r\n",
	       we2_i3c_desc->dynamic_addr, sizeof(cmd), ret);
	if (ret < 0) {
		gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 0);
		printk("[ERROR] WE2 I3C: Set resolution write failed: %d\r\n", ret);
		return ret;
	}
	printk("[WE2 DBG]   delay 50 ms, then GPIO LOW...\r\n");
	k_msleep(50);
	gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 0);
	printk("[INFO] WE2 I3C: Resolution set to %s (0x%02X)\r\n",
	       res == WE2_RES_QQVGA ? "162x122" : (res == WE2_RES_QVGA ? "324x224" : "?"), res);
	return 0;
}

int we2_set_fps(const struct device *i3c_bus, uint8_t fps)
{
	uint8_t cmd[WE2_I3C_CMD_WITH_PAYLOAD_LEN];
	int ret;
	const struct device *gpio6_dev = DEVICE_DT_GET(DT_NODELABEL(gpio6));

	printk("[WE2 DBG] we2_set_fps: target DA=0x%02X fps=%u\r\n",
	       we2_i3c_desc ? we2_i3c_desc->dynamic_addr : 0, fps);

	if (we2_i3c_desc == NULL) {
		printk("[ERROR] WE2 I3C: we2_i3c_desc not set (call we2_init first)\r\n");
		return -ENODEV;
	}
	if (!device_is_ready(gpio6_dev)) {
		printk("[ERROR] WE2 I3C: gpio6 not ready\r\n");
		return -ENODEV;
	}

	cmd[0] = WE2_I3C_CMD_TYPE;
	cmd[1] = WE2_I3C_CMD_SET_FRAME_RATE;
	cmd[2] = WE2_I3C_FLAG_HOST_CMD;
	cmd[3] = WE2_I3C_SET_FRAME_RATE_PAYLOAD_LEN;
	cmd[4] = fps;
	printk("[WE2 DBG]   cmd[] = 0x%02X 0x%02X 0x%02X 0x%02X 0x%02X (len=%zu)\r\n",
	       cmd[0], cmd[1], cmd[2], cmd[3], cmd[4], sizeof(cmd));

	ret = gpio_pin_configure(gpio6_dev, WE2_GPIO_PIN, GPIO_OUTPUT_INACTIVE);
	if (ret < 0) {
		printk("[WE2 DBG]   gpio_pin_configure FAILED: %d\r\n", ret);
		return ret;
	}
	printk("[WE2 DBG]   GPIO P6_7 HIGH, delay 20 ms...\r\n");
	gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 1);
	k_msleep(20);
	ret = i3c_write(we2_i3c_desc, cmd, sizeof(cmd));
	printk("[WE2 DBG]   i3c_write(DA=0x%02X, len=%zu) -> %d\r\n",
	       we2_i3c_desc->dynamic_addr, sizeof(cmd), ret);
	if (ret < 0) {
		gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 0);
		printk("[ERROR] WE2 I3C: Set FPS write failed: %d\r\n", ret);
		return ret;
	}
	printk("[WE2 DBG]   delay 50 ms, GPIO LOW...\r\n");
	k_msleep(50);
	gpio_pin_set(gpio6_dev, WE2_GPIO_PIN, 0);
	printk("[INFO] WE2 I3C: FPS set to %u\r\n", fps);
	return 0;
}

